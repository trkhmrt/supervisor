{
  "name": "supervisor-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true next dev",
    "dev:clean": "rimraf .next node_modules/.cache && cross-env WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true next dev",
    "db:generate": "prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:push:force": "dotenv -e .env.local -- prisma db push --accept-data-loss",
    "db:fix-user-role": "dotenv -e .env.local -- prisma db execute --file scripts/fix-user-role-enum.sql --schema prisma/schema.prisma && dotenv -e .env.local -- prisma db execute --file scripts/fix-user-role-enum-migrate.sql --schema prisma/schema.prisma",
    "db:migrate:datetime": "dotenv -e .env.local -- prisma db execute --file scripts/migrate-string-dates-to-datetime.sql --schema prisma/schema.prisma",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "seed:admin": "dotenv -e .env.local -- npx tsx scripts/seed-admin.ts",
    "seed:supervisor": "dotenv -e .env.local -- npx tsx scripts/seed-supervisor.ts",
    "seed:demo": "dotenv -e .env.local -- npx tsx scripts/seed-demo.ts",
    "seed:all": "dotenv -e .env.local -- npx tsx scripts/seed-admin.ts && dotenv -e .env.local -- npx tsx scripts/seed-demo.ts && dotenv -e .env.local -- npx tsx scripts/seed-supervisor.ts",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.18.2",
    "jose": "^6.2.3",
    "lucide-react": "^0.460.0",
    "next": "14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^7.4.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
