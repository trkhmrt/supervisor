{
  "name": "supervisor-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true next dev",
    "dev:clean": "rm -rf .next node_modules/.cache && WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true next dev",
    "db:generate": "prisma generate",
    "db:push": "node node_modules/dotenv-cli/cli.js -e .env.local -- node scripts/prisma-env.cjs db push",
    "db:migrate": "node node_modules/dotenv-cli/cli.js -e .env.local -- node scripts/prisma-env.cjs migrate dev",
    "db:studio": "node node_modules/dotenv-cli/cli.js -e .env.local -- node scripts/prisma-env.cjs studio",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.460.0",
    "next": "14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^7.4.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.49",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
