# Site (OAuth redirect için production URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Auth
NEXT_PUBLIC_SUPERVISOR_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPERVISOR_SUPABASE_ANON_KEY=your-anon-key

# Kısa isimler (opsiyonel, yukarıdakilerle aynı değerler)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Prisma → Supabase Postgres
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"

# Sunucu tarafı — rol/scope'un Supabase app_metadata + JWT'ye yazılması için gerekli
SUPERVISOR_SUPABASE_SERVICE_ROLE_KEY=

# Admin panel JWT (e-posta/şifre oturumu)
ADMIN_JWT_SECRET=change-me-to-a-long-random-string

# İlk admin seed (scripts/seed-admin.ts)
SEED_ADMIN_EMAIL=admin@supervizyon.com
SEED_ADMIN_PASSWORD=Admin123!
