# Supabase (Next.js istemcisi)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Prisma → Supabase Postgres
#
# Seçenek A — DATABASE_URL: Prisma şemasının beklediği isim (tercihen non-pooling / 5432).
#
# Seçenek B — Sadece Supabase şablonu: POSTGRES_PRISMA_URL veya POSTGRES_URL_NON_POOLING
# yeterlidir; Next.js çalışırken lib/prisma bu sırayla otomatik kullanır.
# CLI: `npm run db:push` aynı fallback’i uygular.
#
DATABASE_URL=
# POSTGRES_PRISMA_URL=   # Supabase "Connection pooling" / Transaction mode
# POSTGRES_URL_NON_POOLING=
