# Site kökü — production'da gerçek domain (localhost YAZMAYIN)
# Örnek: https://supervizyon.com  |  lokal: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Auth
NEXT_PUBLIC_SUPERVISOR_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPERVISOR_SUPABASE_ANON_KEY=your-anon-key

# Kısa isimler (opsiyonel, yukarıdakilerle aynı değerler)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Prisma → Supabase Postgres
# Vercel → Settings → Environment Variables → Production (ve Preview) için ekleyin:
#   DATABASE_URL = Session pooler (port 6543, pgbouncer=true)
#   DIRECT_URL   = Direct connection (port 5432) — olmadan prod'da Prisma hata verebilir
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"

# Supabase (middleware + auth — prod'da zorunlu)
# NEXT_PUBLIC_SUPERVISOR_SUPABASE_URL ve ANON_KEY Vercel'de tanımlı olmalı

# Sunucu tarafı — rol/scope'un Supabase app_metadata + JWT'ye yazılması için gerekli
SUPERVISOR_SUPABASE_SERVICE_ROLE_KEY=

# Admin panel JWT (e-posta/şifre oturumu)
ADMIN_JWT_SECRET=change-me-to-a-long-random-string

# İlk admin seed (scripts/seed-admin.ts)
SEED_ADMIN_EMAIL=admin@supervizyon.com
SEED_ADMIN_PASSWORD=Admin123!

# Demo süpervizör seed (scripts/seed-supervisor.ts — önce seed:demo)
SEED_SUPERVISOR_EMAIL=abdullatif@supervizyon.com
SEED_SUPERVISOR_PASSWORD=Supervisor123!
SEED_SUPERVISOR_ID=sup-1

# E-posta bildirimleri (opsiyonel — yoksa geliştirmede konsola yazılır)
RESEND_API_KEY=
EMAIL_FROM=Süpervizyon <noreply@supervizyon.com>
