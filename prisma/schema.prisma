generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  user
  supervisor
  admin
}

enum AppointmentStatus {
  pending_payment
  confirmed
  completed
  cancelled
  rescheduled
}

enum InviteStatus {
  pending
  accepted
  expired
}

enum SupervisorApplicationStatus {
  pending
  invited
  rejected
}

enum CourseEnrollmentStatus {
  pending
  approved
  rejected
  cancelled
}

model User {
  id               Int              @id @default(autoincrement())
  supabaseAuthId   String?          @unique
  email            String           @unique
  password         String?
  fullName         String
  role             UserRole
  isSuperAdmin     Boolean          @default(false)
  title            String?
  emailVerified    Boolean          @default(false)
  phone            String?
  profession       String?
  experienceYears  Int?
  license          String?
  createdAt        DateTime         @default(now())
  supervisor       Supervisor?
  appointments     Appointment[]    @relation("AppointmentMember")
  courseEnrollments CourseEnrollment[]
  permissions      UserPermission[]

  @@index([role])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String
  users       UserPermission[]
}

model UserPermission {
  userId       Int
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

model Supervisor {
  id                String             @id @default(cuid())
  userId            Int?               @unique
  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  fullName          String
  title             String
  photo             String
  bio               String
  pricePerSession   Int
  currency          String             @default("TRY")
  rating            Float              @default(0)
  reviewCount       Int                @default(0)
  yearsExperience   Int                @default(0)
  license           String
  expertise         String[]
  languages         String[]
  approaches        String[]
  slots             AvailabilitySlot[]
  calendarDays      SupervisorCalendarDay[]
  appointments      Appointment[]
  reviews           Review[]
  courses           Course[]
}

model Course {
  id                  String             @id @default(cuid())
  supervisorId        String
  supervisor          Supervisor         @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  title               String
  slug                String
  description         String
  active              Boolean            @default(true)
  acceptsApplications Boolean            @default(true)
  maxParticipants     Int?
  startsAt            DateTime?
  endsAt              DateTime?
  createdAt           DateTime           @default(now())
  enrollments         CourseEnrollment[]

  @@unique([supervisorId, slug])
  @@index([supervisorId, active])
}

model CourseEnrollment {
  id        String                 @id @default(cuid())
  courseId  String
  course    Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId    Int
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    CourseEnrollmentStatus @default(pending)
  message   String?
  createdAt DateTime               @default(now())

  @@unique([courseId, userId])
  @@index([userId])
  @@index([courseId, status])
}

model AvailabilitySlot {
  id           String     @id @default(cuid())
  supervisorId String
  supervisor   Supervisor @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  startsAt     DateTime
  endsAt       DateTime
  isBooked     Boolean    @default(false)

  @@index([supervisorId, startsAt])
}

// Süpervizör takviminde gün düzeyinde müsait / müsait değil
model SupervisorCalendarDay {
  id           String     @id @default(cuid())
  supervisorId String
  supervisor   Supervisor @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  date         String
  available    Boolean

  @@unique([supervisorId, date])
  @@index([supervisorId])
}

model Appointment {
  id               String            @id @default(cuid())
  supervisorId     String
  supervisor       Supervisor        @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  supervisorName   String
  userId           Int?
  user             User?             @relation("AppointmentMember", fields: [userId], references: [id], onDelete: SetNull)
  superviseeName   String
  superviseeEmail  String
  serviceType      String
  startsAt         DateTime
  endsAt           DateTime
  status           AppointmentStatus @default(pending_payment)
  meetLink         String?
  paymentApproved  Boolean           @default(false)
  amount           Int
  notes            String?
  createdAt        DateTime          @default(now())

  @@index([userId, startsAt(sort: Desc)])
  @@index([supervisorId, startsAt(sort: Desc)])
  @@index([startsAt(sort: Desc)])
  @@index([superviseeEmail])
}

model Service {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  shortDescription String
  description      String
  features         String[]
  icon             String
  price            Int
  duration         Int
  active           Boolean  @default(true)
}

model BlogPost {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  excerpt      String
  content      String
  cover        String
  author       String
  category     String
  tags         String[]
  publishedAt  DateTime
  readingTime  Int
  published    Boolean  @default(false)
}

model Review {
  id            String     @id @default(cuid())
  supervisorId  String
  supervisor    Supervisor @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  authorName    String
  rating        Int
  comment       String
  createdAt     DateTime

  @@index([supervisorId])
}

model SupervisorApplication {
  id        String                      @id @default(uuid())
  fullName  String
  email     String
  message   String?
  status    SupervisorApplicationStatus @default(pending)
  createdAt DateTime                    @default(now())
  invite    SupervisorInvite?

  @@index([status, createdAt(sort: Desc)])
  @@index([email])
}

model SupervisorInvite {
  id              String                 @id @default(uuid())
  token           String                 @unique @default(uuid())
  email           String
  invitedAt       DateTime               @default(now())
  expiresAt       DateTime?
  acceptedAt      DateTime?
  status          InviteStatus           @default(pending)
  applicationId   String?                @unique
  application     SupervisorApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([email, status])
  @@index([expiresAt])
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime
  read      Boolean  @default(false)
}

model SiteSettings {
  id       String @id @default("default")
  siteName String
  tagline  String
  email    String
  phone    String
  address  String
  socials  Json   @default("{}")
}
