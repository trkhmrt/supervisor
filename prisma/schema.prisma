generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  user
  supervisor
  admin
}

enum AppointmentStatus {
  pending_payment
  confirmed
  completed
  cancelled
  rescheduled
}

enum InviteStatus {
  pending
  accepted
  expired
}

enum SupervisorApplicationStatus {
  pending
  invited
  rejected
}

enum CourseEnrollmentStatus {
  pending
  approved
  rejected
  cancelled
}

enum AdDisplayMode {
  IMAGE_ONLY
  IMAGE_WITH_TEXT
}

model User {
  id               Int              @id @default(autoincrement())
  supabaseAuthId   String?          @unique
  email            String           @unique
  password         String?
  fullName         String
  role             UserRole
  isSuperAdmin     Boolean          @default(false)
  title            String?
  emailVerified    Boolean          @default(false)
  phone            String?
  profession       String?
  experienceYears  Int?
  license          String?
  createdAt        DateTime         @default(now())
  supervisor       Supervisor?
  appointments     Appointment[]    @relation("AppointmentMember")
  courseEnrollments CourseEnrollment[]
  permissions      UserPermission[]

  @@index([role])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String
  users       UserPermission[]
}

model UserPermission {
  userId       Int
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

model Supervisor {
  id                String             @id @default(cuid())
  userId            Int?               @unique
  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  fullName          String
  title             String
  photo             String
  bio               String
  pricePerSession   Int
  sessionFeeOnRequest Boolean            @default(false)
  currency          String             @default("TRY")
  rating            Float              @default(0)
  reviewCount       Int                @default(0)
  yearsExperience   Int                @default(0)
  license           String?
  expertise         String[]
  languages         String[]
  approaches        String[]
  services          Service[]          @relation("SupervisorServices")
  slots             AvailabilitySlot[]
  calendarDays      SupervisorCalendarDay[]
  appointments      Appointment[]
  reviews           Review[]
  courses           Course[]
  serviceGroups     ServiceGroup[]
  authorProfile     Author?
}

model Course {
  id                  String             @id @default(cuid())
  supervisorId        String
  supervisor          Supervisor         @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  title               String
  slug                String
  description         String
  active              Boolean            @default(true)
  acceptsApplications Boolean            @default(true)
  maxParticipants     Int?
  startsAt            DateTime?
  endsAt              DateTime?
  createdAt           DateTime           @default(now())
  enrollments         CourseEnrollment[]

  @@unique([supervisorId, slug])
  @@index([supervisorId, active])
}

model CourseEnrollment {
  id        String                 @id @default(cuid())
  courseId  String
  course    Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId    Int
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    CourseEnrollmentStatus @default(pending)
  message   String?
  createdAt DateTime               @default(now())

  @@unique([courseId, userId])
  @@index([userId])
  @@index([courseId, status])
}

model AvailabilitySlot {
  id           String     @id @default(cuid())
  supervisorId String
  supervisor   Supervisor @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  startsAt     DateTime
  endsAt       DateTime
  isBooked     Boolean    @default(false)

  @@index([supervisorId, startsAt])
}

// Süpervizör takviminde gün düzeyinde müsait / müsait değil
model SupervisorCalendarDay {
  id           String     @id @default(cuid())
  supervisorId String
  supervisor   Supervisor @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  date         String
  available    Boolean

  @@unique([supervisorId, date])
  @@index([supervisorId])
}

model Appointment {
  id               String            @id @default(cuid())
  supervisorId     String
  supervisor       Supervisor        @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  supervisorName   String
  userId           Int?
  user             User?             @relation("AppointmentMember", fields: [userId], references: [id], onDelete: SetNull)
  superviseeName   String
  superviseeEmail  String
  superviseePhone  String            @default("")
  serviceType      String
  serviceGroupId   String?
  serviceGroup     ServiceGroup?     @relation(fields: [serviceGroupId], references: [id], onDelete: SetNull)
  startsAt         DateTime
  endsAt           DateTime
  status           AppointmentStatus @default(pending_payment)
  meetLink         String?
  paymentApproved  Boolean           @default(false)
  amount           Int
  notes            String?
  createdAt        DateTime          @default(now())
  groupEnrollment  ServiceGroupEnrollment?

  @@index([userId, startsAt(sort: Desc)])
  @@index([supervisorId, startsAt(sort: Desc)])
  @@index([startsAt(sort: Desc)])
  @@index([superviseeEmail])
  @@index([serviceGroupId])
}

model Service {
  id               String         @id @default(cuid())
  slug             String         @unique
  name             String
  shortDescription String
  description      String
  features         String[]
  icon             String
  price            Int
  duration         Int
  active           Boolean        @default(true)
  isGroupService   Boolean        @default(false)
  supervisors      Supervisor[]   @relation("SupervisorServices")
  groups           ServiceGroup[]
}

model ServiceGroup {
  id           String                   @id @default(cuid())
  supervisorId String
  supervisor   Supervisor               @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  serviceId    String
  service      Service                  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name         String
  capacity     Int
  seatLabel    String?
  sortOrder    Int                      @default(0)
  active       Boolean                  @default(true)
  startsAt     DateTime?
  endsAt       DateTime?
  enrollments  ServiceGroupEnrollment[]
  appointments Appointment[]
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([supervisorId, serviceId, active])
}

model ServiceGroupEnrollment {
  id              String       @id @default(cuid())
  groupId         String
  group           ServiceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  appointmentId   String       @unique
  appointment     Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  superviseeEmail String
  superviseeName  String
  userId          Int?
  createdAt       DateTime     @default(now())

  @@unique([groupId, superviseeEmail])
  @@index([groupId])
}

model BlogPost {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  excerpt      String
  content      String
  cover        String
  author       String
  authorId     String?
  authorRef    Author?  @relation(fields: [authorId], references: [id], onDelete: SetNull)
  category     String
  tags         String[]
  publishedAt  DateTime
  readingTime  Int
  published    Boolean  @default(false)

  @@index([authorId])
}

model Author {
  id           String      @id @default(cuid())
  slug         String      @unique
  fullName     String
  title        String?
  bio          String
  photo        String
  supervisorId String?     @unique
  supervisor   Supervisor? @relation(fields: [supervisorId], references: [id], onDelete: SetNull)
  posts        BlogPost[]
  createdAt    DateTime    @default(now())
}

model Review {
  id            String     @id @default(cuid())
  supervisorId  String
  supervisor    Supervisor @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  authorName    String
  rating        Int
  comment       String
  createdAt     DateTime

  @@index([supervisorId])
}

model SupervisorApplication {
  id        String                      @id @default(uuid())
  fullName  String
  email     String
  phone     String                      @default("")
  message   String?
  status    SupervisorApplicationStatus @default(pending)
  createdAt DateTime                    @default(now())
  invite    SupervisorInvite?

  @@index([status, createdAt(sort: Desc)])
  @@index([email])
}

model SupervisorInvite {
  id              String                 @id @default(uuid())
  token           String                 @unique @default(uuid())
  email           String
  invitedAt       DateTime               @default(now())
  expiresAt       DateTime?
  acceptedAt      DateTime?
  status          InviteStatus           @default(pending)
  applicationId   String?                @unique
  application     SupervisorApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([email, status])
  @@index([expiresAt])
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime
  read      Boolean  @default(false)
}

model SiteSettings {
  id                    String   @id @default("default")
  siteName              String   @default("Süpervizyon")
  tagline               String   @default("")
  email                 String   @default("")
  phone                 String   @default("")
  address               String   @default("")
  socials               Json     @default("{}")
  heroEyebrow           String?
  heroHeadlinePrefix    String?
  heroHeadlineWords     String[] @default([])
  heroHeadlineSuffix    String?
  heroSubtext           String?
  heroPrimaryCtaText    String?
  heroPrimaryCtaHref    String?
  heroSecondaryCtaText  String?
  heroSecondaryCtaHref  String?
  heroStatYears         Int?
  heroStatSessions      Int?
  heroStatRating        Float?
  heroImageUrl          String?
  heroImageAlt          String?
  heroBadgeText         String?
  heroFloatingKeywords  String[] @default([])
  homeTrustLabels       String[] @default([])
  homeWhyEyebrow        String?
  homeWhyTitle          String?
  homeWhyHighlight      String?
  homeWhyFeatureTitles  String[] @default([])
  homeWhyFeatureDescs   String[] @default([])
  homeWhyStepTitles     String[] @default([])
  homeWhyStepDescs      String[] @default([])
  updatedAt             DateTime @default(now()) @updatedAt
}

model Advertisement {
  id          String        @id @default(cuid())
  title       String
  body        String?
  imageUrl    String
  linkUrl     String?
  displayMode AdDisplayMode @default(IMAGE_WITH_TEXT)
  active      Boolean       @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([active, startsAt, endsAt])
}
